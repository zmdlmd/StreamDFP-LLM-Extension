export ROOT="/absolute/path/to/StreamDFP"

# Public Backblaze-style HDD data layout expected by the current scripts.
export DATA_ROOT_HDD="$ROOT/data/data_2014/2014"
export DATA_ROOT="$DATA_ROOT_HDD"

# Feature list used by both the classic and LLM-enhanced pipelines.
export FEATURES_HDD="$ROOT/pyloader/features_erg/hi7_all.txt"
export FEATURES="$FEATURES_HDD"

# Qwen checkpoint path downloaded outside Git.
export MODEL_PATH="/absolute/path/to/models/Qwen/Qwen3.5-4B"

# Shared experiment window.
export REF_START="2014-01-01"
export REF_END="2014-08-31"
export OUT_START="2014-09-01"
export OUT_END="2014-11-09"

# Pilot run defaults used by the public reproducibility guide.
export RUN_TAG="pilot20k_qwen35_public"
export PHASE2_MODELS="m2"
export MAX_WINDOWS="20000"
export SAMPLE_MODE="stratified_day_disk"
export SAMPLE_SEED="42"

# Phase2 inference defaults.
export BATCH_SIZE="8"
export VLLM_GPU_MEMORY_UTILIZATION="0.80"
export VLLM_MAX_MODEL_LEN="3072"
export VLLM_MAX_NUM_BATCHED_TOKENS="1024"
export MAX_NEW_TOKENS="128"
export AUTO_SHUTDOWN="0"

# Phase3 defaults.
export PHASE3_RUN_TAG="$RUN_TAG"
export PHASE3_EXTRACT_MODE="zs"
export PHASE3_PROMPT_PROFILE="structured_v2"
export PHASE3_TAG_SUFFIX="publicqwen35"
export JAVA_XMX="40g"
